import torch
import torch.nn as nn
import torch.optim as optim
from torchvision import models, transforms
from torch.utils.data import Dataset, DataLoader
from PIL import Image
import pandas as pd
import os
from tqdm.notebook import tqdm

# ========== 1. SETUP ==========
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"Using {device}")

# Data paths
train_dir = "/kaggle/input/tammathon-task-1/train"
test_dir = "/kaggle/input/tammathon-task-1/test"
train_csv = pd.read_csv("/kaggle/input/tammathon-task-1/train.csv")
test_csv = pd.read_csv("/kaggle/input/tammathon-task-1/test.csv")

# Transforms
train_transform = transforms.Compose([
    transforms.Resize((256, 256)),
    transforms.RandomCrop(224),
    transforms.RandomHorizontalFlip(p=0.5),
    transforms.ColorJitter(brightness=0.2, contrast=0.2),
    transforms.RandomRotation(15),
    transforms.ToTensor(),
    transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])
])

test_transform = transforms.Compose([
    transforms.Resize((224, 224)),
    transforms.ToTensor(),
    transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])
])

# ========== 2. CUSTOM DATASET ==========
class CatDataset(Dataset):
    def __init__(self, df, img_dir, transform=None, is_test=False): 
        self.df = df.reset_index(drop=True)
        self.img_dir = img_dir
        self.transform = transform
        self.is_test = is_test
        
        if not is_test:
            self.labels = df['label'].unique()
            self.label_to_idx = {label: idx for idx, label in enumerate(self.labels)}
            self.idx_to_label = {idx: label for label, idx in self.label_to_idx.items()}
        
    def __len__(self): 
        return len(self.df)
    
    def __getitem__(self, idx):  
        img_path = os.path.join(self.img_dir, self.df.loc[idx, 'filename'])
        try:
            image = Image.open(img_path).convert("RGB")
            if self.transform:
                image = self.transform(image)
            
            if self.is_test:
                return image, -1
            else:
                label = self.label_to_idx[self.df.loc[idx, 'label']]
                return image, label
        except Exception as e:
            print(f"Error loading {img_path}: {e}")
            dummy_img = torch.zeros(3, 224, 224)
            return dummy_img, 0

# ========== 3. LOADERS ==========
train_dataset = CatDataset(train_csv, train_dir, train_transform)
test_dataset = CatDataset(test_csv, test_dir, test_transform, is_test=True)

batch_size = 64
num_workers = 4 if torch.cuda.is_available() else 2

train_loader = DataLoader(
    train_dataset, 
    batch_size=batch_size, 
    shuffle=True,
    num_workers=num_workers,
    pin_memory=True,
    drop_last=True
)

test_loader = DataLoader(
    test_dataset,
    batch_size=batch_size * 2,
    shuffle=False,
    num_workers=num_workers,
    pin_memory=True
)

# ========== 4. MODEL ==========
model = models.efficientnet_b0(weights=models.EfficientNet_B0_Weights.IMAGENET1K_V1)
num_classes = len(train_dataset.labels)
model.classifier[1] = nn.Linear(model.classifier[1].in_features, num_classes)
model = model.to(device)

criterion = nn.CrossEntropyLoss()
optimizer = optim.AdamW(model.parameters(), lr=0.0003, weight_decay=1e-5)
scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=10)

# ========== 5. TRAINING ==========
for epoch in range(6):
    model.train()
    train_loss = 0

    for images, labels in tqdm(train_loader, desc=f'Epoch {epoch+1}/6'):
        images, labels = images.to(device), labels.to(device)
        
        optimizer.zero_grad()
        outputs = model(images)
        loss = criterion(outputs, labels)
        loss.backward()
        optimizer.step()
        scheduler.step()
        
        train_loss += loss.item()
    
    print(f"Epoch {epoch+1} Loss: {train_loss/len(train_loader):.4f}")

# ========== 6. PREDICTION ==========
model.eval()
predictions = []

with torch.no_grad():
    for images, _ in tqdm(test_loader, desc="Predicting"):
        images = images.to(device)
        outputs = model(images)
        _, top3 = torch.topk(outputs, 3, dim=1)
        predictions.extend(top3.cpu().numpy())

# ========== 7. SUBMISSION ==========
idx_to_label = train_dataset.idx_to_label

submission = pd.DataFrame({
    'filename': test_csv['filename'],
    'label_1': [idx_to_label[p[0]] for p in predictions],
    'label_2': [idx_to_label[p[1]] for p in predictions],
    'label_3': [idx_to_label[p[2]] for p in predictions]
})

submission.to_csv('/kaggle/working/submission.csv', index=False)
print("✅ Submission successfully created and saved!")
print(f"📝 Predictions generated for {len(submission)} test images.")
